NEXT_PUBLIC_APP_NAME="EcoVoyage CRM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Android / Capacitor: URL прод-сайта для WebView (скопируйте в .env.mobile — см. .env.mobile.example)
# CAP_SERVER_URL=https://YOUR-PROJECT.vercel.app

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Для `npm run db:push:env` — достаточно одного из двух (Supabase → Settings → Database):
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"
# SUPABASE_DB_PASSWORD="YOUR_DB_PASSWORD"

RECEIPT_PREFIX="ECO"

# Автопроверка чеков на странице бухгалтера: разбор фото через Google Gemini (опционально)
# GEMINI_API_KEY=
# GEMINI_MODEL=

# PWA Push notifications (Web Push / VAPID)
# Generate once: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# mailto:your-email@company.com
VAPID_SUBJECT=""
