{
  "name": "ecovoyage-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "dev:lan": "node scripts/show-lan-url.mjs && next dev -H 0.0.0.0 -p 3000",
    "dev:clean": "rm -rf .next && next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "db:link": "supabase link",
    "db:push": "supabase db push",
    "db:push:all": "supabase db push --include-all",
    "db:push:env": "node scripts/db-push.mjs",
    "db:push:safe": "node scripts/db-push.mjs --include-all",
    "db:push:auto": "node scripts/db-push.mjs --include-all",
    "mobile:android:init": "npx cap add android",
    "mobile:android-sdk": "node scripts/android-local-properties.mjs",
    "mobile:sync": "node scripts/cap-sync.mjs",
    "mobile:open": "npx cap open android",
    "mobile:apk:debug": "cd android && ./gradlew assembleDebug",
    "mobile:apk:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dejavu-fonts-ttf": "^2.37.3",
    "exceljs": "^4.4.0",
    "googleapis": "^173.0.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "supabase": "^2.84.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
